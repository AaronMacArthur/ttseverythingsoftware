{
  "name": "tts-everything",
  "version": "1.0.0",
  "description": "A local desktop multistream TTS app for Twitch, TikTok, Kick, YouTube, and Rumble.",
  "main": "desktop-main.js",
  "scripts": {
    "start": "node server.js",
    "desktop": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis",
    "tiktok:dev": "node scripts/tiktok-capture.js",
    "tiktok:test": "node --test tests/tiktok-webcast.test.js",
    "test": "node --check server.js && node --check public/dashboard.js && node --check public/combined-chat.js && node --check public/gift-dono.js && node --check desktop-main.js && node --check desktop-preload.js && node --check scripts/tiktok-capture.js && node --test tests/tiktok-webcast.test.js"
  },
  "build": {
    "appId": "com.ttseverything.desktop",
    "productName": "TTS Everything",
    "asar": false,
    "files": [
      "desktop-main.js",
      "desktop-preload.js",
      "server.js",
      "cohostEngine.js",
      "integrations/**/*",
      "public/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TTS Everything"
    },
    "portable": {
      "artifactName": "TTS Everything Portable ${version}.exe"
    }
  },
  "dependencies": {
    "pg": "^8.20.0",
    "playwright-core": "^1.60.0",
    "protobufjs": "^8.3.0",
    "stripe": "^22.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1"
  }
}
